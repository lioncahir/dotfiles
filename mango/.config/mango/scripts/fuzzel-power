#!/bin/bash

choice=$(echo -e "箚뛽 Log out\n箚쨪 Suspend\n箚쐣 Reboot\n箚맓 Shut down" | fuzzel --dmenu --lines 4 -p "Power menu" )

case $choice in
    "箚뛽 Log out")    mmsg -q ;;
    "箚쨪 Suspend")    systemctl suspend ;;
    "箚쐣 Reboot")     systemctl reboot ;; 
    "箚맓 Shut down")  systemctl poweroff ;;
esac
