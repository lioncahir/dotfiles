#!/usr/bin/env bash

outputs_json=$(niri msg --json outputs)
menu_entries=$(echo "$outputs_json" | jq -r 'to_entries[] | "\(.key) (\(.value.make))"')
output=$(echo "$menu_entries" | fuzzel --dmenu --lines 4 -p "Select output" | cut -d " " -f 1) 
[ -z "$output" ] && exit 0

action=$(echo -e "Toggle on/off\nChange scale\nChange resolution" | fuzzel --dmenu --lines 4 -p "Select action")

case $action in
    "Toggle on/off")
            # Determine current state: on if current_mode is non-null, off otherwise
            is_on=$(echo "$outputs_json" | jq --arg name "$output" '.[$name].current_mode != null')

            # Toggle
            if [ "$is_on" = "true" ]; then
                niri msg output "$output" off
            else
                niri msg output "$output" on
            fi

            # Sanity check: if no outputs are active after the toggle, re-enable eDP-1
            sleep 0.3
            active_count=$(niri msg --json outputs | jq '[to_entries[] | select(.value.current_mode != null)] | length')
            if [ "$active_count" -eq 0 ]; then
                notify-send "Display toggle" "All outputs off; re-enabling eDP-1" 2>/dev/null || true
                niri msg output eDP-1 on
            fi
            ;;

    "Change scale")
            scale=$(echo -e "1.0\n1.5\n2.0" | fuzzel --dmenu --lines 4 -p "Select scale")
            [ -z "$scale" ] && exit 0
            niri msg output "$output" scale "$scale"
            ;;

    "Change resolution")
            resolutions=$(niri msg --json outputs | jq -r --arg output "$output" '.[] | select(.name == $output) | [.modes[] | "\(.width)x\(.height)"] | unique[]')
            res=$(echo "$resolutions" | fuzzel --dmenu -p "Select resolution")
            [ -z "$res" ] && exit 0
            niri msg output "$output" mode "$res"
            ;;
esac
